				PBindConfig.DefaultY = tostring(PBindConfig.DefaultY or "")
				PBindConfig.DefaultZ = tostring(PBindConfig.DefaultZ or "")
				PBindConfig.Callback = PBindConfig.Callback or function() end
				PBindConfig.Flag = PBindConfig.Flag or nil
				PBindConfig.Save = PBindConfig.Save or false

				local PBind = {
					ValueX = PBindConfig.DefaultX,
					ValueY = PBindConfig.DefaultY,
					ValueZ = PBindConfig.DefaultZ,
					Type = "PBind",
					Save = PBindConfig.Save
				}

				local Frame = AddThemeObject(SetChildren(SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 5), {
					Size = UDim2.new(1, 0, 0, 40),
					Parent = ItemParent
				}), {
					AddThemeObject(SetProps(MakeElement("Label", PBindConfig.Name, 15), {
						Size = UDim2.new(1, -190, 1, 0),
						Position = UDim2.new(0, 12, 0, 0),
						Font = Enum.Font.GothamBold,
						Name = "Content"
					}), "Text"),
					AddThemeObject(MakeElement("Stroke"), "Stroke")
				}), "Second")

				local Fields = {}
				local Defaults = {PBindConfig.DefaultX, PBindConfig.DefaultY, PBindConfig.DefaultZ}
				local Names = {"X", "Y", "Z"}

				local function cleanNumber(Text)
					local cleaned = tostring(Text or ""):gsub("[^0-9%.%-]", "")
					local sign = string.sub(cleaned, 1, 1) == "-" and "-" or ""
					cleaned = cleaned:gsub("%-", "")
					local firstDot = cleaned:find("%.")
					if firstDot then
						cleaned = cleaned:sub(1, firstDot) .. cleaned:sub(firstDot + 1):gsub("%.", "")
					end
					return sign .. cleaned
				end

				for index = 1, 3 do
					local holder = AddThemeObject(SetChildren(SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 4), {
						Size = UDim2.new(0, 52, 0, 26),
						Position = UDim2.new(1, -((4 - index) * 58), 0.5, -13)
					}), {
						AddThemeObject(MakeElement("Stroke"), "Stroke"),
						AddThemeObject(SetProps(MakeElement("Label", Names[index] .. ":", 12), {
							Size = UDim2.new(0, 16, 1, 0),
							Position = UDim2.new(0, 3, 0, 0),
							Font = Enum.Font.GothamBold
						}), "TextDark")
					}), "Main")

					local box = SetProps(Create("TextBox", {
						Size = UDim2.new(1, -18, 1, 0),
						Position = UDim2.new(0, 18, 0, 0),
						BackgroundTransparency = 1,
						TextColor3 = OrionLib.Themes[OrionLib.SelectedTheme].Text,
						PlaceholderColor3 = OrionLib.Themes[OrionLib.SelectedTheme].TextDark,
						PlaceholderText = "...",
						Font = Enum.Font.GothamBold,
						TextXAlignment = Enum.TextXAlignment.Center,
						TextSize = 12,
						Text = Defaults[index],
						ClearTextOnFocus = false
					}), {Name = Names[index]})
					box.Parent = holder
					holder.Parent = Frame
					Fields[index] = box

					AddConnection(box:GetPropertyChangedSignal("Text"), function()
						local cleaned = cleanNumber(box.Text)
						if cleaned ~= box.Text then box.Text = cleaned end
					end)
				end

				local function updateValues(Invoke)
					PBind.ValueX = Fields[1].Text
					PBind.ValueY = Fields[2].Text
					PBind.ValueZ = Fields[3].Text
					if Invoke then
						PBindConfig.Callback(PBind.ValueX, PBind.ValueY, PBind.ValueZ)
						pcall(function() SaveCfg(game.GameId) end)
					end
				end

				for _, box in ipairs(Fields) do
					AddConnection(box.FocusLost, function() updateValues(true) end)
				end

				function PBind:Set(X, Y, Z)
					if X ~= nil then Fields[1].Text = tostring(X) end
					if Y ~= nil then Fields[2].Text = tostring(Y) end
					if Z ~= nil then Fields[3].Text = tostring(Z) end
					updateValues(false)
				end

				if PBindConfig.Flag then OrionLib.Flags[PBindConfig.Flag] = PBind end
				return PBind
			end

