							Text = NormalizeSearchText(TabName .. " " .. ElementText),
							ElementText = ElementText, Order = Order
						})
					end
				end
			end
		end
		SearchDirty = false
	end
	local function ClearSearchHighlight()
		SearchHighlightToken += 1
		local Theme = GetActiveTheme()
		if ActiveSearchLabel and ActiveSearchLabel.Parent then ActiveSearchLabel.TextColor3 = Theme.Text end
		if ActiveSearchStroke and ActiveSearchStroke.Parent then
			ActiveSearchStroke.Color, ActiveSearchStroke.Thickness = Theme.Stroke, 1
		end
		ActiveSearchLabel, ActiveSearchStroke = nil, nil
	end
	local function AnimateSearchResult(Label)
		ClearSearchHighlight()
		local Token, Frame = SearchHighlightToken, Label and Label.Parent
		if not (Frame and Frame:IsA("GuiObject")) then return end
		local Theme, Highlight = GetActiveTheme(), GetActiveTheme().Accent
		local Scale = Frame:FindFirstChild("SearchScale") or Instance.new("UIScale")
		Scale.Name, Scale.Scale, Scale.Parent = "SearchScale", 1, Frame
		local Grow = TweenService:Create(Scale, TweenInfo.new(0.14, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1.025})
		Grow:Play()
		Grow.Completed:Once(function()
			if Scale.Parent then TweenService:Create(Scale, TweenInfo.new(0.16), {Scale = 1}):Play() end
		end)
		ActiveSearchLabel, Label.TextColor3 = Label, Highlight
		local Stroke = Frame:FindFirstChildOfClass("UIStroke")
		if Stroke then
			ActiveSearchStroke, Stroke.Color, Stroke.Thickness = Stroke, Highlight, 2
		end
		task.delay(0.42, function()
			if Token ~= SearchHighlightToken then return end
			if Label.Parent then Label.TextColor3 = GetActiveTheme().Text end
			if Stroke and Stroke.Parent then Stroke.Color, Stroke.Thickness = GetActiveTheme().Stroke, 1 end
			ActiveSearchLabel, ActiveSearchStroke = nil, nil
		end)
	end
	function OrionLib:Search(Query, Limit)
		Query = NormalizeSearchText(Query)
		if Query == "" then return {} end
		if SearchDirty then RebuildSearchIndex() end
		local Results = {}
		for _, Entry in ipairs(SearchIndex) do
			local Score = ScoreNormalizedSearch(Entry.ElementText or Entry.Text, Query)
			if Score <= 0 and Entry.ElementText then Score = ScoreNormalizedSearch(Entry.Text, Query) * 0.82 end
			if Score > 0 then
				table.insert(Results, {Entry = Entry, Score = Score})
			end
		end
		table.sort(Results, function(A, B)
			if A.Score == B.Score then return A.Entry.Order < B.Entry.Order end
			return A.Score > B.Score
		end)
		while #Results > (Limit or 8) do table.remove(Results) end
		return Results
	end
	function OrionLib:FindAndFocusElement(Query)
		local Result = self:Search(Query, 1)[1]
		if not Result then return false end
		local Entry = Result.Entry
		self:GoToTab(Entry.Tab)
		task.defer(function()
			if not Entry.IsTab and Entry.Frame and Entry.Frame.Parent then
				self:ScrollToElement(Entry.Tab, Entry.Frame, true, "center")
			end
			if Entry.Label and Entry.Label.Parent then AnimateSearchResult(Entry.Label) end
		end)
		return true
	end
