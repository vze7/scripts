local function UnlockMouse(Value)
	if mouseUnlockConnection then
		mouseUnlockConnection:Disconnect()
		mouseUnlockConnection = nil
	end
	if Value then
		mouselock = true
		UserInputService.MouseIconEnabled = true
		freeMouse.Visible = true
		mouseUnlockConnection = RunService.Heartbeat:Connect(function()
			if not mouselock then return end
			if not UserInputService.MouseIconEnabled then
				UserInputService.MouseIconEnabled = true
			end
			if not freeMouse.Visible then
				freeMouse.Visible = true
			end
		end)
	else
		mouselock = false
		UserInputService.MouseIconEnabled = false
		freeMouse.Visible = false
	end
end
