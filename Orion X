	AddConnection(RunService.RenderStepped, function(deltaTime)
		if deltaTime <= 0 then return end
		frameCounter += 1
		frameAccumulator += deltaTime
		if frameAccumulator >= 0.4 then
			local sampledFPS = frameCounter / frameAccumulator
			smoothedFPS = smoothedFPS == 0 and sampledFPS or (smoothedFPS * 0.72 + sampledFPS * 0.28)
			frameCounter = 0
			frameAccumulator = 0
		end
	end)

