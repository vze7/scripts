			latitude, longitude = tonumber(lat), tonumber(lon)
			localCountryCode = tostring(location.country or "")
		end
		if not latitude or not longitude then
			location = readJson("https://ipwho.is/")
			latitude = location and tonumber(location.latitude)
			longitude = location and tonumber(location.longitude)
			localCountryCode = tostring(location and location.country_code or localCountryCode)
