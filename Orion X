							task.wait(0.1)
						end
					end)
				end
				AddConnection(SliderBar.InputBegan, function(Input)
					if (Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch) and SliderBar.Active then
						Dragging = true
						Slider.IsClicking = true
						DragInput = Input
					end
				end)
				AddConnection(SliderBar.InputChanged, function(Input)
					if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
