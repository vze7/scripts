			local function captureChildren()
				local children = {}
				for _, child in ipairs(ItemParent:GetChildren()) do
					children[child] = true
				end
				return children
			end

			local function findNewRoot(Before)
				local root
				for _, child in ipairs(ItemParent:GetChildren()) do
					if not Before[child] and child:IsA("GuiObject") then
						root = child
					end
				end
				return root
			end

			local function attachLifecycle(Handle, Root)
				if type(Handle) ~= "table" or not Root then return Handle end
				Handle.Instance = Root
				if Handle.toggle == nil then
					function Handle:toggle()
						if Root.Parent then Root.Visible = not Root.Visible end
						return Root.Visible
					end
				end
				if Handle.remove == nil then
					function Handle:remove()
						if Root.Parent then DestroyElement(Root) end
					end
				end
				if Handle.Destroy == nil then Handle.Destroy = Handle.remove end
				if Handle.SetVisible == nil then
					function Handle:SetVisible(Value)
						if Root.Parent then Root.Visible = Value == true end
					end
				end
				return Handle
			end

			local factories = {
				"AddLabel", "AddPlayerParagraph", "AddParagraph", "AddButton", "AddToggle",
				"AddSlider", "AddPlayersDropdown", "AddDropdown", "AddBind", "AddTextbox",
				"AddColorpicker", "AddLog", "ColorLabel", "AddPbind"
			}
			for _, methodName in ipairs(factories) do
				local FactoryName = methodName
				local OriginalFactory = ElementFunction[FactoryName]
				if OriginalFactory then
					ElementFunction[FactoryName] = function(self, ...)
						local Before = captureChildren()
						local Handle = OriginalFactory(self, ...)
						local Root = findNewRoot(Before)
						Handle = attachLifecycle(Handle, Root)

						if FactoryName == "AddLabel" and type(Handle) == "table" and Root and Handle.Set then
							local OriginalSet = Handle.Set
							function Handle:Set(NewText, ColorMap)
								if ColorMap then
									Root.Content.RichText = true
									Root.Content.Text = applyColorMap(NewText, ColorMap)
								else
									OriginalSet(self, NewText)
								end
							end
						end

						return Handle
					end
				end
			end
			ElementFunction.AddPBind = ElementFunction.AddPbind

			return ElementFunction
		end

