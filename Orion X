local function LoadCfg(Config)
	local ok, Data = pcall(HttpService.JSONDecode, HttpService, Config)
	if not ok or type(Data) ~= "table" then
		warn("Orion Library Config Loader - Invalid config JSON")
		return
	end
	for a, b in pairs(Data) do
		local Flag = OrionLib.Flags[a]
		if Flag then
			task.spawn(function()
				if Flag.Type == "Colorpicker" then
					if type(b) == "table" and b.R then
						Flag:Set(UnpackColor(b))
					elseif type(b) == "table" and b[1] then
						Flag:Set(b)
					end
				elseif Flag.Type == "MultiColorpicker" and type(b) == "table" then
					if b[1] then
						local colors = {}
						for i, c in ipairs(b) do
							colors[i] = (type(c) == "table" and c.R) and UnpackColor(c) or c
						end
						Flag:Set(colors)
					end
				elseif Flag.Type == "PBind" and type(b) == "table" then
					Flag:Set(b.x, b.y, b.z)
				else
					Flag:Set(b)
				end
			end)
		else
			warn("Orion Library Config Loader - Could not find ", a, b)
		end
	end
end
SaveCfg = function(Name)
	if not CanUseFiles() or not OrionLib.Folder then return false end
	if not EnsureFolder(OrionLib.Folder) then return false end
	local Data = {}
	for i, v in pairs(OrionLib.Flags) do
		if v.Save then
			if v.Type == "Colorpicker" then
				if typeof(v.Value) == "Color3" then
					Data[i] = PackColor(v.Value)
				elseif type(v.Value) == "table" then
					local packed = {}
					for j, c in ipairs(v.Value) do
						packed[j] = typeof(c) == "Color3" and PackColor(c) or c
					end
					Data[i] = packed
				end
			elseif v.Type == "MultiColorpicker" then
				local packed = {}
				if v.Pickers then
					for j, p in ipairs(v.Pickers) do
						packed[j] = PackColor(p.Value)
					end
				elseif type(v.Value) == "table" then
					for j, c in ipairs(v.Value) do
						packed[j] = typeof(c) == "Color3" and PackColor(c) or c
					end
				end
				Data[i] = packed
			elseif v.Type == "PBind" then
				Data[i] = {x = v.ValueX, y = v.ValueY, z = v.ValueZ}
			else
				Data[i] = v.Value
			end
		end
	end
	local ok = pcall(writefile, OrionLib.Folder .. "/" .. tostring(Name) .. ".txt", HttpService:JSONEncode(Data))
	return ok
end
