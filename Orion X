-- Visual controls exposed in the UI Config tab.
-- Visibility uses 0-100: 0 = invisible, 100 = fully visible.
local VisualPreferences = {
	StrokeVisibility = 0,
	SeparatorVisibility = 0,
	KeystrokeBackgroundVisibility = 0,
	KeystrokeStrokeVisibility = 0,
	KeystrokeCornerRadius = 2,
	KeystrokePressedStrength = 28,
	CornerRadius = 10,
}
OrionLib.VisualPreferences = VisualPreferences

local ManagedCorners = {}

local function VisibilityToTransparency(Value)
	return 1 - (math.clamp(tonumber(Value) or 0, 0, 100) / 100)
end

local function MixColor(From, To, Amount)
	Amount = math.clamp(tonumber(Amount) or 0, 0, 1)
	return Color3.new(
		From.R + (To.R - From.R) * Amount,
		From.G + (To.G - From.G) * Amount,
		From.B + (To.B - From.B) * Amount
	)
end

local function GetKeystrokeVisual(Theme, Pressed)
	if not Pressed then
		return Theme.Second, Theme.Stroke, Theme.Text
	end

	local strength = math.clamp(tonumber(VisualPreferences.KeystrokePressedStrength) or 28, 0, 100) / 100
	-- Pressed keys use a softened accent instead of the full saturated accent.
	local background = MixColor(Theme.Second, Theme.Accent, strength)
	local stroke = MixColor(Theme.Stroke, Theme.Accent, math.min(0.65, strength * 1.15))
	local text = MixColor(Theme.Text, Theme.Accent, math.min(0.35, strength * 0.45))
	return background, stroke, text
end

local function RegisterManagedCorner(Corner, Scale, Offset)
	if not Corner then return Corner end
	Scale = tonumber(Scale) or 0
	Offset = tonumber(Offset) or 0

	-- Scale-based corners (avatars/circles/pills) keep their original shape.
	-- Pixel-based corners are controlled by the global Roundness slider.
	if Scale == 0 then
		table.insert(ManagedCorners, Corner)
		Corner.CornerRadius = UDim.new(0, math.clamp(VisualPreferences.CornerRadius, 0, 32))
	else
		Corner.CornerRadius = UDim.new(Scale, Offset)
	end
	return Corner
end

local function ApplyCornerRadius()
	local radius = math.clamp(tonumber(VisualPreferences.CornerRadius) or 0, 0, 32)
	for index = #ManagedCorners, 1, -1 do
		local Corner = ManagedCorners[index]
		if not Corner or Corner.Parent == nil then
			table.remove(ManagedCorners, index)
		else
			Corner.CornerRadius = UDim.new(0, radius)
		end
	end
end

local function ApplyVisualPreferenceToObject(Object, Type)
	if not Object then return end
	if Type == "Stroke" then
		if Object:IsA("UIStroke") then
			local visibility = Object:GetAttribute("OrionKeystrokeStroke")
				and VisualPreferences.KeystrokeStrokeVisibility
				or VisualPreferences.StrokeVisibility
			Object.Transparency = VisibilityToTransparency(visibility)
		elseif Object:IsA("Frame") then
			-- Frames registered as Stroke are the one-pixel separator lines.
			Object.BackgroundTransparency = VisibilityToTransparency(VisualPreferences.SeparatorVisibility)
		end
	end
end

function AddThemeObject(Object, Type)
    if not OrionLib.ThemeObjects[Type] then
        OrionLib.ThemeObjects[Type] = {}
    end

    Total.AddThemeObject = Total.AddThemeObject + 1
    table.insert(OrionLib.ThemeObjects[Type], Object)

    local themeColor = OrionLib.Themes[OrionLib.SelectedTheme][Type]
    local property = ReturnProperty(Object)

    if themeColor and property and Object[property] ~= nil then
        Object[property] = themeColor
    end

    ApplyVisualPreferenceToObject(Object, Type)
    return Object
end

local function RemoveThemeObject(Object)
	for _, objects in pairs(OrionLib.ThemeObjects) do
		for index = #objects, 1, -1 do
			if objects[index] == Object or objects[index].Parent == nil then
				table.remove(objects, index)
			end
		end
	end
end

local function DestroyElement(Root)
	for _, object in ipairs(Root:GetDescendants()) do
		RemoveThemeObject(object)
	end
	RemoveThemeObject(Root)
	Root:Destroy()
end

local GlobalSearch = Instance.new("TextBox")

local function lighterHSV(color: Color3, factor: number)
	factor = math.clamp(factor, 0, 1)

	local h, s, v = color:ToHSV()

	v = math.clamp(v + factor, 0, 1)
	s = math.clamp(s * (1 - factor * 0.25), 0, 1)

	return Color3.fromHSV(h, s, v)
end

local function smartMidColor(color: Color3)
	local _, _, v = color:ToHSV()

	if v < 0.5 then
		return lighterHSV(color, 0.45)
	else
		return darkerColor(color, 0.45)
	end
end

function darkerColor(color, factor)
	factor = math.clamp(factor, 0, 1)
	return Color3.new(
		color.R * factor,
		color.G * factor,
		color.B * factor
	)
end

function createGradientFromColor(baseColor, darkFactor)
	local dark = darkerColor(baseColor, darkFactor)

	return ColorSequence.new({
		ColorSequenceKeypoint.new(0, baseColor),
		ColorSequenceKeypoint.new(0.5, dark),
		ColorSequenceKeypoint.new(1, baseColor),
	})
end

mainWindowStroke = Instance.new("UIStroke")
local mainWindowGradient = Instance.new("UIGradient", mainWindowStroke)

local function ApplyVisualPreferences()
	local strokeObjects = OrionLib.ThemeObjects.Stroke or {}
	for _, Object in ipairs(strokeObjects) do
		if Object and Object.Parent then
			ApplyVisualPreferenceToObject(Object, "Stroke")
		end
	end

	if mainWindowStroke then
		mainWindowStroke.Transparency = VisibilityToTransparency(VisualPreferences.StrokeVisibility)
	end
	ApplyCornerRadius()
end

function OrionLib:SetTheme()
	local themeData = self.Themes[self.SelectedTheme]
	if not themeData then return end
	for typeName, objects in pairs(self.ThemeObjects) do
		local color = themeData[typeName]
		if color then
			for _, obj in ipairs(objects) do
				local prop = ReturnProperty(obj)
				if prop and obj[prop] ~= nil then
					obj[prop] = color
				end
			end
		end
	end

	if self.Toggles then
		for _, toggle in ipairs(self.Toggles) do
			if toggle and toggle.Box and toggle.Box.Parent then
				local accolor = toggle.uccolor and toggle.ccolor or themeData.Accent

				if toggle.Value then
					toggle.Box.BackgroundColor3 = accolor
					if toggle.Box.Stroke then
						toggle.Box.Stroke.Color = accolor
					end
				else
					toggle.Box.BackgroundColor3 = themeData.Divider
					if toggle.Box.Stroke then
						toggle.Box.Stroke.Color = themeData.Stroke
					end
				end
			end
		end
	end

	for _, key in ipairs(self.Keystrokes) do
		if key.Frame and key.Frame.Parent then
			local backgroundColor, strokeColor, textColor = GetKeystrokeVisual(themeData, key.Pressed)
			key.Frame.BackgroundColor3 = backgroundColor
			key.Frame.BackgroundTransparency = VisibilityToTransparency(VisualPreferences.KeystrokeBackgroundVisibility)
			key.Stroke.Color = strokeColor
			key.Stroke.Transparency = VisibilityToTransparency(VisualPreferences.KeystrokeStrokeVisibility)
			if key.Corner then
				key.Corner.CornerRadius = UDim.new(0, math.clamp(tonumber(VisualPreferences.KeystrokeCornerRadius) or 0, 0, 16))
			end
			if key.Label then
				key.Label.TextColor3 = textColor
			end
		end
	end

	if mainWindowGradient then
		mainWindowGradient.Color = createGradientFromColor(themeData["Stroke"], 0.7)
	end

	if SearchBarsTXTBox then
		for _, obj in pairs(SearchBarsTXTBox) do
			obj.PlaceholderColor3 = themeData.Text
			obj.TextColor3 = themeData.Text
			obj.BackgroundColor3 = themeData.Main
		end
	end

	if GlobalSearch then
		GlobalSearch.PlaceholderColor3 = themeData.Text
		GlobalSearch.TextColor3 = themeData.Text
		GlobalSearch.BackgroundColor3 = themeData.Main
	end

	ApplyVisualPreferences()
	OrionLib:SaveThemeCfg()
end

