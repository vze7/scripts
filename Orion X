		local requested = tostring(UIState.TemperatureUnit or "Auto")
		if requested == "Celsius" then return "C" end
		if requested == "Fahrenheit" then return "F" end
		if requested == "Kelvin" then return "K" end
		return FahrenheitCountries[string.upper(localCountryCode)] and "F" or "C"
	end
	local function formatTemperature()
		if not localTemperatureC then return "--°" end
		local unit = resolveTemperatureUnit()
		local value = localTemperatureC
		if unit == "F" then
			value = (value * 9 / 5) + 32
		elseif unit == "K" then
			value += 273.15
		end
		return string.format("%d°%s", math.floor(value + 0.5), unit)
	end
