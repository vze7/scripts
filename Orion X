	local RESIZE_INTERVAL = 1 / 60

	local function getResizeMaximum()
		local camera = workspace.CurrentCamera
		local viewport = camera and camera.ViewportSize or Vector2.new(1920, 1080)
		local absolutePosition = window.AbsolutePosition
		return Vector2.new(
			math.max(MIN_SIZE.X, viewport.X - math.max(absolutePosition.X, 0) - 8),
			math.max(MIN_SIZE.Y, viewport.Y - math.max(absolutePosition.Y, 0) - 8)
		)
	end

	local function updateResize(force, currentPosition)
		if not resizing or Minimized then return end
		local now = os.clock()
		if not force and now - lastResizeUpdate < RESIZE_INTERVAL then return end
		local pointer = currentPosition or UserInputService:GetMouseLocation()
		local delta = pointer - startMousePos
		local maximum = getResizeMaximum()
		local size = Vector2.new(
			math.floor(math.clamp(startSize.X + delta.X, MIN_SIZE.X, maximum.X) + 0.5),
			math.floor(math.clamp(startSize.Y + delta.Y, MIN_SIZE.Y, maximum.Y) + 0.5)
		)
		if not force and lastAppliedSize and (size - lastAppliedSize).Magnitude < 1 then return end
		lastResizeUpdate = now
		lastAppliedSize = size
		ExpandedSize = size
		window.Size = UDim2.fromOffset(size.X, size.Y)
		updateSidebarLayout()
		updateTopBarResponsiveness()
	end

