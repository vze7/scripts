local function NormalizeSearchText(Value)
	local Text = string.lower(tostring(Value or ""))
	if Text == "" then return "" end
	for Accent, Plain in pairs(SEARCH_ACCENTS) do
		if string.find(Text, Accent, 1, true) then
			Text = string.gsub(Text, Accent, Plain)
		end
	end
	Text = string.gsub(Text, "[^%w%s_@%-]", " ")
	return (string.gsub(Text, "%s+", " "):match("^%s*(.-)%s*$")) or ""
end
local function IsSearchSubsequence(Needle, Text)
	local Position = 1
	for Index = 1, #Needle do
		Position = string.find(Text, string.sub(Needle, Index, Index), Position, true)
		if not Position then return false end
		Position += 1
	end
	return true
end
local function ScoreNormalizedSearch(Text, Query)
	if Query == "" then return 1 end
	if Text == Query then return 10000 end
	local Score = 0
	if string.sub(Text, 1, #Query) == Query then Score += 4000 end
	if string.find(" " .. Text, " " .. Query, 1, true) then Score += 2400 end
	if string.find(Text, Query, 1, true) then Score += 1200 end
	for Token in string.gmatch(Query, "%S+") do
		local Start = string.find(Text, Token, 1, true)
		if Start then
			Score += Start == 1 and 700 or 420
		elseif #Token >= 3 and IsSearchSubsequence(Token, Text) then
			Score += 90
		else
			return 0
		end
	end
	return Score - math.max(0, #Text - #Query) * 0.02
end
