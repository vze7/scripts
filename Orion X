		activeSearchLabel = nil
		activeSearchStroke = nil
	end

	local function animateSearchResult(label)
		clearSearchHighlight()
		local token = searchHighlightToken
		local frame = label.Parent
		if not frame or not frame:IsA("GuiObject") then return end
		local theme = OrionLib.Themes[OrionLib.SelectedTheme]
		local highlightColor = theme.Accent or theme.Stroke or theme.Text
		local scale = frame:FindFirstChild("SearchScale") or Instance.new("UIScale")
		scale.Name, scale.Scale, scale.Parent = "SearchScale", 1, frame
		local grow = TweenService:Create(scale, TweenInfo.new(0.16, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale=1.035})
		grow:Play()
		grow.Completed:Once(function()
			TweenService:Create(scale, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Scale=1}):Play()
		end)
		activeSearchLabel = label
		label.TextColor3 = highlightColor
		task.delay(0.35, function()
			if token == searchHighlightToken and label.Parent then
				label.TextColor3 = OrionLib.Themes[OrionLib.SelectedTheme].Text
				activeSearchLabel = nil
			end
		end)
		local stroke = frame:FindFirstChildOfClass("UIStroke")
		if not stroke then return end
		activeSearchStroke = stroke
		stroke.Color = highlightColor
		stroke.Thickness = 3
		task.delay(0.35, function()
			if token == searchHighlightToken and stroke.Parent then
				stroke.Thickness = 1
				stroke.Color = OrionLib.Themes[OrionLib.SelectedTheme].Stroke
				activeSearchStroke = nil
			end
		end)
	end

	function OrionLib:FindAndFocusElement(query)
		query = normalizeSearchText(query)
		if query == "" then return false end
		local compactQuery = string.gsub(query, " ", "")
		local matchedTab
		local matchedTabScore = 0
		for _, tabName in ipairs(TabsOrder) do
			local tabText = normalizeSearchText(tabName)
			local compactTab = string.gsub(tabText, " ", "")
			local score = 0
			if tabText == query then
				score = 10000
			elseif string.sub(tabText, 1, #query) == query then
				score = 9000 - (#tabText - #query)
			elseif string.sub(compactTab, 1, #compactQuery) == compactQuery then
				score = 8000 - (#compactTab - #compactQuery)
			elseif #compactQuery >= 4 and isSubsequence(compactQuery, compactTab) then
				score = 7000 - (#compactTab - #compactQuery)
			end
			if score > matchedTabScore then matchedTab, matchedTabScore = tabName, score end
		end
		if matchedTab then
			OrionLib:GoToTab(matchedTab)
			animateSearchResult(Tabs[matchedTab].Frame.Title)
			return true
		end
		if searchDirty then rebuildSearchIndex() end
		local best, bestScore = nil, 0
		for _, entry in ipairs(searchIndex) do
			local score = scoreSearch(entry.Text, query)
			if score > bestScore then best, bestScore = entry, score end
		end
		if not best then return false end
		OrionLib:GoToTab(best.Tab)
		task.wait()
		if not best.IsTab then OrionLib:ScrollToElement(best.Tab, best.Label.Parent, true, "center") end
		animateSearchResult(best.Label)
		return true
	end

