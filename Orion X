	function TabFunction:SetName(...)
		local args = {...}
		local plainText = ""
		local richText = ""
		local function escapeRichText(value)
			value = tostring(value or "")
			value = string.gsub(value, "&", "&amp;")
			value = string.gsub(value, "<", "&lt;")
			value = string.gsub(value, ">", "&gt;")
			return value
		end
		if #args == 1 and type(args[1]) == "string" then
			plainText = args[1]
			richText = escapeRichText(args[1])
		else
			for _, pairData in ipairs(args) do
				if type(pairData) == "table" then
					local text = tostring(pairData[1] or "")
					local color = tostring(pairData[2] or "#FFFFFF")
					plainText ..= text
					richText ..= '<font color="' .. color .. '">' .. escapeRichText(text) .. '</font>'
				else
					local text = tostring(pairData)
					plainText ..= text
					richText ..= escapeRichText(text)
				end
			end
		end
		WindowConfig.Name = plainText
		WindowConfig.RichName = richText
		CompactWindowName = plainText:match("^%s*(.-)%s+[-|]%s+") or plainText
		WindowNameTBX = TextService:GetTextSize(plainText, WindowName.TextSize, Enum.Font.GothamBlack, Vector2.new(math.huge, math.huge))
		CompactWindowNameTBX = TextService:GetTextSize(CompactWindowName, WindowName.TextSize, Enum.Font.GothamBlack, Vector2.new(math.huge, math.huge))
