			local function applyColorMap(Text, ColorMap)
				local result = tostring(Text or "")
				if type(ColorMap) ~= "table" then return result end
				for word, color in pairs(ColorMap) do
					local escapedWord = tostring(word):gsub("([%(%)%.%+%-%*%?%[%]%^%$%%])", "%%%1")
					result = result:gsub(escapedWord, '<font color="' .. tostring(color) .. '">' .. tostring(word) .. '</font>')
				end
				return result
			end
