function OrionLib:SetTheme()
	if self._ThemeApplying then return end
	self._ThemeApplying = true
	local ok, err = pcall(function()
		local themeData = GetRawTheme()
		self.CurrentRenderTheme = themeData
		for typeName, objects in pairs(self.ThemeObjects) do
			local color = themeData[typeName]
			if color then
				for index = #objects, 1, -1 do
					local obj = objects[index]
					if not obj or obj.Parent == nil then
						table.remove(objects, index)
					elseif obj:GetAttribute("OrionKeystroke") ~= true
						and obj.Name ~= "Keystrokes"
						and not (obj.Parent and (obj.Parent.Name == "Keystrokes" or obj.Parent:GetAttribute("OrionKeystroke") == true)) then
						local prop = ReturnProperty(obj)
						if prop then
							pcall(function()
								obj[prop] = color
							end)
						end
					end
				end
			end
		end
		if self.Toggles then
			for _, toggle in ipairs(self.Toggles) do
				if toggle and toggle.Box and toggle.Box.Parent then
					local accolor = toggle.uccolor and toggle.ccolor or themeData.Accent
					if toggle.Value then
						toggle.Box.BackgroundColor3 = accolor
						if toggle.Box.Stroke then toggle.Box.Stroke.Color = accolor end
					else
						toggle.Box.BackgroundColor3 = themeData.Divider
						if toggle.Box.Stroke then toggle.Box.Stroke.Color = themeData.Stroke end
					end
				end
			end
		end
		local keyTheme = GetRawTheme()
		for _, key in ipairs(self.Keystrokes) do
			if key.Frame and key.Frame.Parent then
				local backgroundColor, strokeColor, textColor = GetKeystrokeVisual(keyTheme, key.Pressed)
				key.Frame.BackgroundColor3 = backgroundColor
				key.Frame.BackgroundTransparency = VisibilityToTransparency(VisualPreferences.KeystrokeBackgroundVisibility)
				key.Stroke.Color = strokeColor
				key.Stroke.Transparency = VisibilityToTransparency(VisualPreferences.KeystrokeStrokeVisibility)
				if key.Corner then
					key.Corner.CornerRadius = UDim.new(0, math.clamp(tonumber(VisualPreferences.KeystrokeCornerRadius) or 0, 0, 16))
				end
				if key.Label then key.Label.TextColor3 = textColor end
			end
		end
		if mainWindowGradient then
			mainWindowGradient.Color = createGradientFromColor(themeData.Stroke, 0.7)
		end
		for index = #SearchBarsTXTBox, 1, -1 do
			local obj = SearchBarsTXTBox[index]
			if not obj or obj.Parent == nil then
				table.remove(SearchBarsTXTBox, index)
			else
				obj.PlaceholderColor3 = themeData.TextDark or themeData.Text
				obj.TextColor3 = themeData.Text
				obj.BackgroundColor3 = themeData.Main
			end
		end
		if GlobalSearch and GlobalSearch.Parent then
			GlobalSearch.PlaceholderColor3 = themeData.TextDark or themeData.Text
			GlobalSearch.TextColor3 = themeData.Text
			GlobalSearch.BackgroundColor3 = themeData.Main
		end
		ApplyVisualPreferences()
		for Index = #self.ThemeRefreshers, 1, -1 do
			local Refresh = self.ThemeRefreshers[Index]
			local Success, Keep = pcall(Refresh, themeData)
			if not Success or Keep == false then table.remove(self.ThemeRefreshers, Index) end
		end
		OrionLib:SaveThemeCfg()
	end)
	self._ThemeApplying = false
	if not ok then
		warn("OrionX theme refresh failed: " .. tostring(err))
	end
end
