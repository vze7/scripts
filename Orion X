	local function setFpsSampling(enabled)
		if enabled then
			if L.fpsConn then return end
			frameCounter, frameAccumulator = 0, 0
			L.fpsConn = RunService.Heartbeat:Connect(function(deltaTime)
				if deltaTime <= 0 then return end
				frameCounter += 1
				frameAccumulator += deltaTime
				if frameAccumulator >= 0.5 then
					local sampledFPS = frameCounter / frameAccumulator
					smoothedFPS = smoothedFPS == 0 and sampledFPS or (smoothedFPS * 0.72 + sampledFPS * 0.28)
					frameCounter = 0
					frameAccumulator = 0
					if UIState.ShowFPS then updateLocalInfoText() end
				end
			end)
			table.insert(OrionLib.Connections, L.fpsConn)
