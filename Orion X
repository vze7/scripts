	local accentMap = { ["á"]="a", ["à"]="a", ["â"]="a", ["ã"]="a", ["é"]="e", ["ê"]="e", ["í"]="i", ["ó"]="o", ["ô"]="o", ["õ"]="o", ["ú"]="u", ["ç"]="c" }
	local searchIndex, searchDirty, searchRequest = {}, true, 0

	local function normalizeSearchText(value)
		local text = string.lower(tostring(value or ""))
		for accent, plain in pairs(accentMap) do text = string.gsub(text, accent, plain) end
		text = string.gsub(text, "[^%w%s]", " ")
		return string.gsub(text, "%s+", " "):match("^%s*(.-)%s*$")
	end

	local function isSubsequence(needle, text)
		local position = 1
		for index = 1, #needle do
			position = string.find(text, string.sub(needle, index, index), position, true)
			if not position then return false end
			position += 1
		end
		return true
	end

	local function scoreSearch(text, query)
		if text == query then return 1000 end
		local score = string.sub(text, 1, #query) == query and 400 or 0
		if string.find(" " .. text, " " .. query, 1, true) then score += 250 end
		if string.find(text, query, 1, true) then score += 150 end
		for token in string.gmatch(query, "%S+") do
			if string.find(text, token, 1, true) then
				score += 80
			elseif #token >= 3 and isSubsequence(token, text) then
				score += 20
			else
				return 0
			end
		end
		return score
	end

	local function rebuildSearchIndex()
		table.clear(searchIndex)
		for _, tabName in ipairs(TabsOrder) do
			local tab = Tabs[tabName]
			table.insert(searchIndex, {
				Tab = tabName,
				Label = tab.Frame.Title,
				Text = normalizeSearchText(tabName),
				IsTab = true,
			})
			for _, element in ipairs(tab.Container:GetDescendants()) do
				if element:IsA("TextLabel") and (element.Name == "Content" or element.Name == "Title") then
					local text = normalizeSearchText(element.ContentText)
					if text ~= "" then table.insert(searchIndex, {Tab=tabName, Label=element, Text=text}) end
				end
			end
		end
		searchDirty = false
	end

	local activeSearchLabel
	local activeSearchStroke
	local searchHighlightToken = 0

	local function clearSearchHighlight()
		searchHighlightToken += 1
		local theme = OrionLib.Themes[OrionLib.SelectedTheme]
		if activeSearchLabel and activeSearchLabel.Parent then activeSearchLabel.TextColor3 = theme.Text end
		if activeSearchStroke and activeSearchStroke.Parent then
