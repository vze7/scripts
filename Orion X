				SliderConfig.Callback = SliderConfig.Callback or function() end
				SliderConfig.ValueName = SliderConfig.ValueName or ""
				local SliderUsesThemeAccent = SliderConfig.Color == nil
				SliderConfig.Color = SliderConfig.Color or GetActiveTheme().Accent
				SliderConfig.Flag = SliderConfig.Flag or nil
				SliderConfig.Save = SliderConfig.Save or false
				SliderConfig.VarFunc = SliderConfig.VarFunc or SliderConfig.varFunc
				SliderConfig.Block = SliderConfig.Block
				local IsInfinite = SliderConfig.Max == math.huge
				local InfiniteThreshold = 0.95
				local InfiniteFiniteMax = SliderConfig.InfiniteFiniteMax or math.max(math.abs(SliderConfig.Min) * 5, 100)
				local Slider = {
					Value = SliderConfig.Default,
					Save = SliderConfig.Save,
