			function ElementFunction:AddSlider(SliderConfig)
				SliderConfig = SliderConfig or {}
				SliderConfig.Name = SliderConfig.Name or "Slider"
				SliderConfig.Min = SliderConfig.Min or 0
				SliderConfig.Max = SliderConfig.Max or 100
				SliderConfig.Increment = SliderConfig.Increment or 1
				SliderConfig.Default = SliderConfig.Default == nil and 50 or SliderConfig.Default
				SliderConfig.Callback = SliderConfig.Callback or function() end
				SliderConfig.ValueName = SliderConfig.ValueName or ""
				SliderConfig.Color = SliderConfig.Color or OrionLib.Themes[OrionLib.SelectedTheme].Accent
				SliderConfig.Flag = SliderConfig.Flag or nil
				SliderConfig.Save = SliderConfig.Save or false
				SliderConfig.VarFunc = SliderConfig.VarFunc or SliderConfig.varFunc
				SliderConfig.Block = SliderConfig.Block

				local IsInfinite = SliderConfig.Max == math.huge
				local InfiniteThreshold = 0.95
				local InfiniteFiniteMax = SliderConfig.InfiniteFiniteMax or math.max(math.abs(SliderConfig.Min) * 5, 100)
				local Slider = {
					Value = SliderConfig.Default,
					Save = SliderConfig.Save,
					Type = "Slider",
					IsClicking = false
				}
				local Dragging = false
				local DragInput
				local BlockTask

				local function formatValue(Value)
					if Value == math.huge then return "∞" end
					if math.abs(Value) >= 1000000 then return string.format("%.1fM", Value / 1000000) end
					if math.abs(Value) >= 1000 then return string.format("%.1fK", Value / 1000) end
					return tostring(math.floor(Value * 100 + 0.5) / 100)
				end

				local function valueToScale(Value)
					if IsInfinite then
						if Value == math.huge then return 1 end
						local denominator = InfiniteFiniteMax - SliderConfig.Min
						if denominator == 0 then return 0 end
						return math.clamp(((Value - SliderConfig.Min) / denominator) * InfiniteThreshold, 0, InfiniteThreshold)
					end
					if SliderConfig.Max == SliderConfig.Min then return 0 end
					return math.clamp((Value - SliderConfig.Min) / (SliderConfig.Max - SliderConfig.Min), 0, 1)
				end

				local SliderDrag = SetChildren(SetProps(MakeElement("RoundFrame", SliderConfig.Color, 0, 5), {
					Size = UDim2.new(0, 0, 1, 0),
					BackgroundTransparency = 0.3,
					ClipsDescendants = true
				}), {
					AddThemeObject(SetProps(MakeElement("Label", "value", 13), {
						Size = UDim2.new(1, -12, 0, 14),
						Position = UDim2.new(0, 12, 0, 6),
						Font = Enum.Font.GothamBold,
						Name = "Value"
					}), "Text")
				})

				local SliderBar = SetChildren(SetProps(MakeElement("RoundFrame", SliderConfig.Color, 0, 5), {
					Size = UDim2.new(1, -24, 0, 26),
					Position = UDim2.new(0, 12, 0, 30),
					BackgroundTransparency = 0.9,
					Active = true
				}), {
					SetProps(MakeElement("Stroke"), {Color = SliderConfig.Color}),
					AddThemeObject(SetProps(MakeElement("Label", "value", 13), {
						Size = UDim2.new(1, -12, 0, 14),
						Position = UDim2.new(0, 12, 0, 6),
						Font = Enum.Font.GothamBold,
						Name = "Value",
						TextTransparency = 0.8
					}), "Text"),
					SliderDrag
				})

				local SliderFrame = AddThemeObject(SetChildren(SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 4), {
					Size = UDim2.new(1, 0, 0, 65),
					Parent = ItemParent
				}), {
					AddThemeObject(SetProps(MakeElement("Label", SliderConfig.Name, 15), {
						Size = UDim2.new(1, -12, 0, 14),
						Position = UDim2.new(0, 12, 0, 10),
						Font = Enum.Font.GothamBold,
						Name = "Content"
					}), "Text"),
					AddThemeObject(MakeElement("Stroke"), "Stroke"),
					SliderBar
				}), "Second")

				local function setBlocked(Blocked)
					SliderBar.Active = not Blocked
					local targetTransparency = Blocked and 0.96 or 0.9
					TweenService:Create(SliderBar, TweenInfo.new(0.2), {BackgroundTransparency = targetTransparency}):Play()
					SliderFrame.Content.TextTransparency = Blocked and 0.45 or 0
				end

				if SliderConfig.Block then
					BlockTask = task.spawn(function()
						while SliderFrame.Parent do
							local ok, blocked = pcall(function()
								local source = SliderConfig.Block[1]
								local key = SliderConfig.Block[2]
								local data = SliderConfig.VarFunc and SliderConfig.VarFunc(source) or source
								if type(data) ~= "table" then return true end
								return not data[key]
							end)
							setBlocked(not ok or blocked)
							task.wait(0.1)
						end
					end)
				end

				AddConnection(SliderBar.InputBegan, function(Input)
					if (Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch) and SliderBar.Active then
						Dragging = true
						Slider.IsClicking = true
						DragInput = Input
					end
				end)

				AddConnection(SliderBar.InputChanged, function(Input)
					if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
						DragInput = Input
					end
				end)

				AddConnection(UserInputService.InputEnded, function(Input)
					if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
						Dragging = false
						Slider.IsClicking = false
						DragInput = nil
					end
				end)

				AddConnection(UserInputService.InputChanged, function(Input)
					if not Dragging or not SliderBar.Active then return end
					if Input ~= DragInput and Input.UserInputType ~= Enum.UserInputType.MouseMovement and Input.UserInputType ~= Enum.UserInputType.Touch then return end
					local scale = math.clamp((Input.Position.X - SliderBar.AbsolutePosition.X) / math.max(SliderBar.AbsoluteSize.X, 1), 0, 1)
					local value
					if IsInfinite then
						if scale >= InfiniteThreshold then
							value = math.huge
						else
							value = SliderConfig.Min + (InfiniteFiniteMax - SliderConfig.Min) * (scale / InfiniteThreshold)
						end
					else
						value = SliderConfig.Min + (SliderConfig.Max - SliderConfig.Min) * scale
					end
					Slider:Set(value)
					pcall(function() SaveCfg(game.GameId) end)
				end)

				function Slider:Set(Value)
					local finalValue = Value
					if Value ~= math.huge then
						finalValue = math.clamp(Round(tonumber(Value) or SliderConfig.Min, SliderConfig.Increment), SliderConfig.Min, SliderConfig.Max)
					elseif not IsInfinite then
						finalValue = SliderConfig.Max
					end
					self.Value = finalValue
					TweenService:Create(SliderDrag, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
						Size = UDim2.fromScale(valueToScale(finalValue), 1)
					}):Play()
					local valueText = formatValue(finalValue) .. (SliderConfig.ValueName ~= "" and (" " .. SliderConfig.ValueName) or "")
					SliderBar.Value.Text = valueText
					SliderDrag.Value.Text = valueText
					pcall(SliderConfig.Callback, finalValue)
				end

				function Slider:SetName(NewName)
					SliderConfig.Name = tostring(NewName)
					SliderFrame.Content.Text = SliderConfig.Name
				end

				function Slider:SetMax(NewMax)
					SliderConfig.Max = NewMax
					IsInfinite = NewMax == math.huge
					if not IsInfinite and self.Value > NewMax then
						self:Set(NewMax)
					else
						self:Set(self.Value)
					end
				end

				function Slider:SetMin(NewMin)
					SliderConfig.Min = NewMin
					InfiniteFiniteMax = SliderConfig.InfiniteFiniteMax or math.max(math.abs(NewMin) * 5, 100)
					if self.Value ~= math.huge and self.Value < NewMin then
						self:Set(NewMin)
					else
						self:Set(self.Value)
					end
				end

				AddConnection(SliderFrame.Destroying, function()
					Dragging = false
					Slider.IsClicking = false
					if BlockTask then
						pcall(task.cancel, BlockTask)
						BlockTask = nil
					end
				end)

				Slider:Set(Slider.Value)
				if SliderConfig.Flag then OrionLib.Flags[SliderConfig.Flag] = Slider end
				return Slider
			end

