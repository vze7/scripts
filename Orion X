    function TabFunction:AddConfigTab()
        local config_tab = TabFunction:MakeTab({
            Name = "UI Config",
            Icon = "rbxassetid://15911231575",
            PremiumOnly = false
        })
		if not LoadedThemeFile then
			LoadThemeCfg(FILE_PATH)
		end
		local function heading(Name)
			return config_tab:AddParagraph(Name, "nil", "Center")
		end
		heading("Theme")
		local BaseColorPicker
		BaseColorPicker = config_tab:AddColorpicker({
			Name = "Base Color",
			Default = GetRawTheme().Main,
			Mode = 2,
			Callback = function(Value)
				if typeof(Value) ~= "Color3" then return end
				OrionLib.Themes.Custom = OrionLib:GenTheme(Value)
				OrionLib.SelectedTheme = "Custom"
				OrionLib:SetTheme()
			end
		})
		config_tab:AddButton({
			Name = "Reset Theme",
			Callback = function()
				BaseColorPicker:Set(Color3.fromRGB(25, 25, 25))
			end
		})
		heading("Window Appearance")
		config_tab:AddSlider({
			Name = "Border Visibility",
			Min = 0,
			Max = 100,
			Default = VisualPreferences.StrokeVisibility,
			Increment = 1,
			ValueName = "%",
			Callback = function(Value)
				VisualPreferences.StrokeVisibility = Value
				UIState.StrokeVisibility = Value
				ApplyVisualPreferences()
				scheduleUIConfigSave()
			end,
		})
		config_tab:AddSlider({
			Name = "Separator Visibility",
			Min = 0,
			Max = 100,
			Default = VisualPreferences.SeparatorVisibility,
			Increment = 1,
			ValueName = "%",
			Callback = function(Value)
				VisualPreferences.SeparatorVisibility = Value
				UIState.SeparatorVisibility = Value
				ApplyVisualPreferences()
				scheduleUIConfigSave()
			end,
		})
		config_tab:AddSlider({
			Name = "Border Thickness",
			Min = 0,
			Max = 3,
			Default = UIState.BorderThickness,
			Increment = 0.1,
			ValueName = "Thickness",
			Callback = function(Value)
				mainWindowStroke.Thickness = Value
				UIState.BorderThickness = Value
				scheduleUIConfigSave()
			end,
		})
		config_tab:AddSlider({
			Name = "Roundness",
			Min = 0,
			Max = 24,
			Default = VisualPreferences.CornerRadius,
			Increment = 1,
			ValueName = "px",
			Callback = function(Value)
				VisualPreferences.CornerRadius = Value
				UIState.CornerRadius = Value
				ApplyCornerRadius()
				scheduleUIConfigSave()
			end,
		})
		config_tab:AddToggle({
			Name = "Camera World Blur",
			Default = UIState.BlurEnabled == true,
			Callback = function(Value)
				TabFunction:SetBlur(Value)
			end,
		})
		config_tab:AddSlider({
			Name = "Camera Blur Strength",
			Min = 0,
			Max = 56,
			Default = UIState.BlurSize,
			Increment = 1,
			ValueName = "",
			Callback = function(Value)
				BlurSize = Value
				UIState.BlurSize = Value
				updateBlur()
				scheduleUIConfigSave()
			end,
		})
		heading("Top Bar Information")
		config_tab:AddToggle({
			Name = "Show FPS",
			Default = UIState.ShowFPS == true,
			Callback = function(Value)
				UIState.ShowFPS = Value == true
				setFpsSampling(UIState.ShowFPS)
				L.localInfoText = ""
				updateLocalInfoText()
				scheduleUIConfigSave()
			end,
		})
		config_tab:AddToggle({
			Name = "Show Network Ping (RTT)",
			Default = UIState.ShowPing == true,
			Callback = function(Value)
				UIState.ShowPing = Value == true
				updateLocalInfoText()
				scheduleUIConfigSave()
			end,
		})
		config_tab:AddToggle({
			Name = "Show Clock",
			Default = UIState.ShowClock == true,
			Callback = function(Value)
				UIState.ShowClock = Value == true
				updateLocalInfoText()
				scheduleUIConfigSave()
			end,
		})
		config_tab:AddToggle({
			Name = "Show Temperature",
			Default = UIState.ShowTemperature == true,
			Callback = function(Value)
				UIState.ShowTemperature = Value == true
				updateLocalInfoText()
				scheduleUIConfigSave()
			end,
		})
		config_tab:AddDropdown({
			Name = "Temperature Unit",
			Default = tostring(UIState.TemperatureUnit or "Auto"),
			Options = {"Auto", "Celsius", "Fahrenheit", "Kelvin"},
			Callback = function(Value)
				UIState.TemperatureUnit = tostring(Value)
				updateLocalInfoText()
				scheduleUIConfigSave()
			end,
		})
		if not IsMobile then
			heading("Keystrokes")
			config_tab:AddToggle({
				Name = "Show Keystrokes",
				Default = UIState.ShowKeystrokes == true,
				Callback = function(Value)
					TabFunction:SetKeystrokes(Value)
				end,
			})
			config_tab:AddToggle({
				Name = "Lock Position",
				Default = UIState.KeystrokesLocked == true,
				Callback = function(Value)
					TabFunction:SetKeystrokesLocked(Value)
				end,
			})
			config_tab:AddSlider({
				Name = "Key Border Visibility",
				Min = 0,
				Max = 100,
				Default = VisualPreferences.KeystrokeStrokeVisibility,
				Increment = 1,
				ValueName = "%",
				Callback = function(Value)
					VisualPreferences.KeystrokeStrokeVisibility = Value
					UIState.KeystrokeStrokeVisibility = Value
					ApplyVisualPreferences()
					scheduleUIConfigSave()
				end,
			})
			config_tab:AddSlider({
				Name = "Key Background Visibility",
				Min = 0,
				Max = 100,
				Default = VisualPreferences.KeystrokeBackgroundVisibility,
				Increment = 1,
				ValueName = "%",
				Callback = function(Value)
					VisualPreferences.KeystrokeBackgroundVisibility = Value
					UIState.KeystrokeBackgroundVisibility = Value
					if KeystrokesFrame then
						KeystrokesFrame.BackgroundTransparency = 1
					end
					for _, Item in ipairs(OrionLib.Keystrokes) do
						if Item.Frame and Item.Frame.Parent then
							Item.Frame.BackgroundTransparency = VisibilityToTransparency(Value)
						end
					end
					scheduleUIConfigSave()
				end,
			})
			config_tab:AddSlider({
				Name = "Key Roundness",
				Min = 0,
				Max = 14,
				Default = VisualPreferences.KeystrokeCornerRadius,
				Increment = 1,
				ValueName = "px",
				Callback = function(Value)
					VisualPreferences.KeystrokeCornerRadius = Value
					UIState.KeystrokeCornerRadius = Value
					for _, Item in ipairs(OrionLib.Keystrokes) do
						if Item.Corner and Item.Corner.Parent then
							Item.Corner.CornerRadius = UDim.new(0, Value)
						end
					end
					scheduleUIConfigSave()
				end,
			})
			config_tab:AddSlider({
				Name = "Pressed Color Strength",
				Min = 0,
				Max = 100,
				Default = VisualPreferences.KeystrokePressedStrength,
				Increment = 1,
				ValueName = "%",
				Callback = function(Value)
					VisualPreferences.KeystrokePressedStrength = Value
					UIState.KeystrokePressedStrength = Value
					OrionLib:SetTheme()
					scheduleUIConfigSave()
				end,
			})
		end
		heading("Save")
		config_tab:AddToggle({
			Name = "Auto Save UI",
			Default = UIState.AutoSave ~= false,
			Callback = function(Value)
				UIState.AutoSave = Value == true
				saveUIConfig(true)
			end,
		})
		config_tab:AddButton({
			Name = "Save UI Now",
			Callback = function()
				captureWindowGeometry()
				saveUIConfig(true)
			end,
		})
		updateLocalInfoText()
		updateBlur()
		saveUIConfig(false)
    end
	return TabFunction
end
function OrionLib:Destroy()
	UnlockMouse(false)
	for _, Connection in pairs(OrionLib.Connections) do
		pcall(function() Connection:Disconnect() end)
	end
	table.clear(OrionLib.Connections)
	table.clear(OrionLib.ThemeObjects)
	table.clear(OrionLib.ThemeRefreshers)
	table.clear(OrionLib.Toggles)
	table.clear(OrionLib.Keystrokes)
	table.clear(OrionLib.Dropdowns)
	table.clear(OrionLib.Flags)
	table.clear(SearchBarsTXTBox)
	table.clear(ManagedCorners)
	if Orion and Orion.Parent then
		Orion:Destroy()
	end
end
function OrionLib:DestroyLib()
	self:Destroy()
end
function OrionLib:SaveConfig(Name)
	return SaveCfg(Name or game.GameId)
end
return OrionLib
