	local function clampWindowToViewport()
		local camera = workspace.CurrentCamera
		local viewport = camera and camera.ViewportSize or Vector2.new(1920, 1080)
		local size = MainWindow.AbsoluteSize
		local current = MainWindow.AbsolutePosition
		local x = math.clamp(current.X, 4, math.max(4, viewport.X - size.X - 4))
		local y = math.clamp(current.Y, 4, math.max(4, viewport.Y - size.Y - 4))
		if math.abs(x - current.X) > 0.5 or math.abs(y - current.Y) > 0.5 then
			MainWindow.Position = UDim2.fromOffset(math.floor(x + 0.5), math.floor(y + 0.5))
		end
	end

