			Max = 100,
			Default = VisualPreferences.SeparatorVisibility,
			Increment = 1,
			ValueName = "%",
			Callback = function(Value)
				VisualPreferences.SeparatorVisibility = Value
				UIState.SeparatorVisibility = Value
				ApplyVisualPreferences()
				scheduleUIConfigSave()
			end,
		})

		windowstroke:AddSlider({
			Name = "Border Thickness",
			Min = 0,
			Max = 3,
			Default = UIState.BorderThickness,
			Color = Color3.fromRGB(59, 122, 179),
			Increment = 0.1,
			ValueName = "Thickness",
			Callback = function(Value)
				mainWindowStroke.Thickness = Value
				UIState.BorderThickness = Value
				scheduleUIConfigSave()
			end,
		})

		windowstroke:AddSlider({
			Name = "Roundness",
			Min = 0,
			Max = 24,
			Default = VisualPreferences.CornerRadius,
			Increment = 1,
			ValueName = "px",
			Callback = function(Value)
				VisualPreferences.CornerRadius = Value
				UIState.CornerRadius = Value
				ApplyCornerRadius()
				scheduleUIConfigSave()
			end,
		})

		topbar_info:AddToggle({
			Name = "Show FPS",
			Default = UIState.ShowFPS == true,
			Callback = function(Value)
				UIState.ShowFPS = Value == true
				updateLocalInfoText()
				scheduleUIConfigSave()
			end,
		})

		topbar_info:AddToggle({
			Name = "Show Ping",
			Default = UIState.ShowPing == true,
			Callback = function(Value)
				UIState.ShowPing = Value == true
				updateLocalInfoText()
				scheduleUIConfigSave()
			end,
		})

		topbar_info:AddToggle({
			Name = "Show Clock",
			Default = UIState.ShowClock == true,
			Callback = function(Value)
				UIState.ShowClock = Value == true
				updateLocalInfoText()
				scheduleUIConfigSave()
			end,
		})

		topbar_info:AddToggle({
			Name = "Show Temperature",
			Default = UIState.ShowTemperature == true,
			Callback = function(Value)
				UIState.ShowTemperature = Value == true
				updateLocalInfoText()
				scheduleUIConfigSave()
			end,
		})

		topbar_info:AddDropdown({
			Name = "Temperature Unit",
			Default = tostring(UIState.TemperatureUnit or "Auto"),
			Options = {"Auto", "Celsius", "Fahrenheit", "Kelvin"},
			Callback = function(Value)
				UIState.TemperatureUnit = tostring(Value)
				updateLocalInfoText()
				scheduleUIConfigSave()
			end,
		})

		persistence:AddToggle({
			Name = "Auto Save UI",
			Default = UIState.AutoSave ~= false,
			Callback = function(Value)
				UIState.AutoSave = Value == true
				-- Force one final write so the disabled state itself is remembered.
				saveUIConfig(true)
			end,
		})

		persistence:AddButton({
			Name = "Save UI Now",
			Callback = function()
				captureWindowGeometry()
				saveUIConfig(true)
			end,
		})

		select_theme:AddColorpicker({
			Name = "Base Color",
			Default = OrionLib.Themes[OrionLib.SelectedTheme].Main,
			Mode = 2,
			Callback = function(Value)
				local newTheme = OrionLib:GenTheme(Value)
				OrionLib.Themes.Custom = newTheme
				OrionLib.SelectedTheme = "Custom"
				OrionLib:SetTheme()

			end
		})

		select_theme:AddButton({
			Name = "Reset Theme",
			Callback = function()
				OrionLib.Themes.Custom = OrionLib:GenTheme(Color3.fromRGB(25, 25, 25))
				OrionLib.SelectedTheme = "Custom"
				OrionLib:SetTheme()
			end
		})

		LoadThemeCfg(FILE_PATH)
		updateLocalInfoText()
		updateBlur()
		saveUIConfig(false)
    end

	return TabFunction
end

function OrionLib:Destroy()
	Orion:Destroy()
end

function OrionLib:DestroyLib()
	self:Destroy()
end

function OrionLib:SaveConfig(Name)
	SaveCfg(Name or game.GameId)
end

return OrionLib
