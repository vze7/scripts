				local function formatValue(Value)
					if Value == math.huge then return "∞" end
					if math.abs(Value) >= 1000000 then return string.format("%.1fM", Value / 1000000) end
					if math.abs(Value) >= 1000 then return string.format("%.1fK", Value / 1000) end
					return tostring(math.floor(Value * 100 + 0.5) / 100)
				end
				local function valueToScale(Value)
					if IsInfinite then
						if Value == math.huge then return 1 end
						local denominator = InfiniteFiniteMax - SliderConfig.Min
						if denominator == 0 then return 0 end
						return math.clamp(((Value - SliderConfig.Min) / denominator) * InfiniteThreshold, 0, InfiniteThreshold)
					end
					if SliderConfig.Max == SliderConfig.Min then return 0 end
					return math.clamp((Value - SliderConfig.Min) / (SliderConfig.Max - SliderConfig.Min), 0, 1)
				end
				local function themeSliderObject(object)
					if SliderUsesThemeAccent then
						return AddThemeObject(object, "Accent")
					end
					return object
				end
				local SliderDrag = themeSliderObject(SetChildren(SetProps(MakeElement("RoundFrame", SliderConfig.Color, 0, 5), {
