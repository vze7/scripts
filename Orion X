function OrionLib:GenTheme(mainColor)
	local function mix(a, b, amount)
		return Color3.new(
			a.R + (b.R - a.R) * amount,
			a.G + (b.G - a.G) * amount,
			a.B + (b.B - a.B) * amount
		)
	end
	local lum = 0.2126 * mainColor.R + 0.7152 * mainColor.G + 0.0722 * mainColor.B
	local dark = lum < 0.5
	local h, s, v = mainColor:ToHSV()
	local t = {Main = mainColor}

	if dark then
		t.Second = mix(mainColor, Color3.new(1, 1, 1), 0.07)
		t.Divider = mix(mainColor, Color3.new(1, 1, 1), 0.12)
		t.Stroke = mix(mainColor, Color3.new(1, 1, 1), 0.2)
		t.Text = Color3.fromRGB(241, 241, 245)
		t.TextDark = Color3.fromRGB(158, 158, 168)
		t.Accent = s < 0.16 and Color3.fromRGB(103, 132, 255) or Color3.fromHSV(h, math.clamp(s, 0.55, 0.85), math.max(v, 0.74))
	else
		t.Second = mix(mainColor, Color3.new(0, 0, 0), 0.04)
		t.Divider = mix(mainColor, Color3.new(0, 0, 0), 0.09)
		t.Stroke = mix(mainColor, Color3.new(0, 0, 0), 0.18)
		t.Text = Color3.fromRGB(31, 31, 36)
		t.TextDark = Color3.fromRGB(103, 103, 114)
		t.Accent = s < 0.16 and Color3.fromRGB(72, 100, 220) or Color3.fromHSV(h, math.clamp(s, 0.5, 0.8), math.min(v, 0.62))
	end

	return t
end

