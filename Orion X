function OrionLib:GenTheme(mainColor)
	local function mix(a, b, amount)
		amount = math.clamp(amount, 0, 1)
		return Color3.new(
			a.R + (b.R - a.R) * amount,
			a.G + (b.G - a.G) * amount,
			a.B + (b.B - a.B) * amount
		)
	end
	local function linear(channel)
		return channel <= 0.04045 and (channel / 12.92) or (((channel + 0.055) / 1.055) ^ 2.4)
	end
	local function luminance(color)
		return 0.2126 * linear(color.R) + 0.7152 * linear(color.G) + 0.0722 * linear(color.B)
	end
	local lum = luminance(mainColor)
	local whiteContrast = 1.05 / (lum + 0.05)
	local blackContrast = (lum + 0.05) / 0.05
	local useLightText = whiteContrast >= blackContrast
	local h, s, v = mainColor:ToHSV()
	local t = {Main = mainColor}
	if useLightText then
		t.Second = mix(mainColor, Color3.new(1, 1, 1), 0.075)
		t.Divider = mix(mainColor, Color3.new(1, 1, 1), 0.13)
		t.Stroke = mix(mainColor, Color3.new(1, 1, 1), 0.23)
		t.Text = Color3.fromRGB(246, 246, 249)
		t.TextDark = mix(t.Text, mainColor, 0.46)
		if s < 0.10 then
			t.Accent = Color3.fromRGB(188, 188, 198)
		else
			t.Accent = Color3.fromHSV(h, math.clamp(s, 0.48, 0.88), math.max(v, 0.72))
		end
	else
		t.Second = mix(mainColor, Color3.new(0, 0, 0), 0.055)
		t.Divider = mix(mainColor, Color3.new(0, 0, 0), 0.105)
		t.Stroke = mix(mainColor, Color3.new(0, 0, 0), 0.19)
		t.Text = Color3.fromRGB(24, 24, 29)
		t.TextDark = mix(t.Text, mainColor, 0.46)
		if s < 0.10 then
			t.Accent = Color3.fromRGB(78, 78, 88)
		else
			t.Accent = Color3.fromHSV(h, math.clamp(s, 0.45, 0.82), math.min(v, 0.60))
		end
	end
	return t
end
