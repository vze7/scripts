			if type(location.timezone) == "table" and type(location.timezone.utc) == "string" then
				local sign, hours, minutes = location.timezone.utc:match("([+-])(%d%d):?(%d%d)")
				if sign then
					localUtcOffset = (tonumber(hours) * 60 + tonumber(minutes)) * 60 * (sign == "-" and -1 or 1)
