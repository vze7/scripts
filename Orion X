					SliderFrame.Content.Text = SliderConfig.Name
				end
				function Slider:SetMax(NewMax)
					SliderConfig.Max = NewMax
					IsInfinite = NewMax == math.huge
					if not IsInfinite and self.Value > NewMax then
						self:Set(NewMax)
					else
						self:Set(self.Value)
					end
				end
				function Slider:SetMin(NewMin)
					SliderConfig.Min = NewMin
					InfiniteFiniteMax = SliderConfig.InfiniteFiniteMax or math.max(math.abs(NewMin) * 5, 100)
					if self.Value ~= math.huge and self.Value < NewMin then
						self:Set(NewMin)
					else
						self:Set(self.Value)
					end
				end
				AddConnection(SliderFrame.Destroying, function()
					Dragging = false
					Slider.IsClicking = false
					if BlockTask then
						pcall(task.cancel, BlockTask)
						BlockTask = nil
					end
				end)
				Slider:Set(Slider.Value)
				if SliderConfig.Flag then OrionLib.Flags[SliderConfig.Flag] = Slider end
				return Slider
			end
			local function TruncateLabelText(Label, Text, MaxWidth)
				Text = tostring(Text or "")
				if TextService:GetTextSize(Text, Label.TextSize, Label.Font, Vector2.new(math.huge, math.huge)).X <= MaxWidth then return Text end
				local Low, High = 0, #Text
				while Low < High do
					local Middle = math.ceil((Low + High) / 2)
					local Candidate = string.sub(Text, 1, Middle) .. "..."
					if TextService:GetTextSize(Candidate, Label.TextSize, Label.Font, Vector2.new(math.huge, math.huge)).X <= MaxWidth then
						Low = Middle
					else
						High = Middle - 1
					end
				end
				return string.sub(Text, 1, Low) .. "..."
			end
