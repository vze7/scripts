				local TextBox_s = DropdownFrame.F:FindFirstChild("TextBoxSearch") or ""

				function Dropdown:Refresh(Options, Delete)
					if Delete then
						for _, v in pairs(Dropdown.Buttons) do
							if v.Button then
								v.Button:Destroy()
							end
						end

						table.clear(Dropdown.Options)
						table.clear(Dropdown.Buttons)
					end

					Dropdown.Options = Options
					AddOptions(Dropdown.Options)
					FilterOptions(TextBox_s and TextBox_s.Text or "")
				end

				function Dropdown:Set(Value)
					local SelectedData

					for _, data in pairs(Dropdown.Buttons) do
						if data.Id == Value or data.Name == Value then
							SelectedData = data
							break
						end
					end

					if not SelectedData then
						return
					end

					if DropdownConfig.MultipleSelection then
						local index = table.find(Dropdown.Value, SelectedData.Id)

						if index then
							table.remove(Dropdown.Value, index)

							TweenService:Create(SelectedData.Button,
								TweenInfo.new(.15),
								{BackgroundTransparency = 1}
							):Play()

							TweenService:Create(SelectedData.Button.Title,
								TweenInfo.new(.15),
								{TextTransparency = 0.4}
							):Play()
						else
							table.insert(Dropdown.Value, SelectedData.Id)

							TweenService:Create(SelectedData.Button,
								TweenInfo.new(.15),
								{BackgroundTransparency = 0}
							):Play()

							TweenService:Create(SelectedData.Button.Title,
								TweenInfo.new(.15),
								{TextTransparency = 0}
							):Play()
						end

						local SelectedNames = {}

						for _, SelectedId in pairs(Dropdown.Value) do
							for _, data in pairs(Dropdown.Buttons) do
								if data.Id == SelectedId then
									table.insert(SelectedNames, data.Name)
									break
								end
							end
						end

						local text = table.concat(SelectedNames, ", ")

						local maxWidth = DropdownFrame.F.Selected.AbsoluteSize.X - 250
						maxWidth = math.max(maxWidth, 50)

						DropdownFrame.F.Selected.Text = TruncateText(
							DropdownFrame.F.Selected,
							text,
							maxWidth
						)

						return DropdownConfig.Callback(SelectedNames)
					end

					if not SelectedData then
						Dropdown.Value = "..."

						DropdownFrame.F.Selected.Text = Dropdown.Value

						for _, v in pairs(Dropdown.Buttons) do
							TweenService:Create(v.Button,
								TweenInfo.new(.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
								{BackgroundTransparency = 1}
							):Play()

							TweenService:Create(v.Button.Title,
								TweenInfo.new(.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
								{TextTransparency = 0.4}
							):Play()
						end

						return
					end

					Dropdown.Value = SelectedData.Name

					local maxWidth = DropdownFrame.F.Selected.AbsoluteSize.X - 250
					maxWidth = math.max(maxWidth, 50)

					DropdownFrame.F.Selected.Text = TruncateText(
						DropdownFrame.F.Selected,
						tostring(SelectedData.Name),
						maxWidth
					)

					for _, v in pairs(Dropdown.Buttons) do
						TweenService:Create(v.Button,
							TweenInfo.new(.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
							{BackgroundTransparency = 1}
						):Play()

						TweenService:Create(v.Button.Title,
							TweenInfo.new(.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
							{TextTransparency = 0.4}
						):Play()
					end

					TweenService:Create(SelectedData.Button,
						TweenInfo.new(.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
						{BackgroundTransparency = 0}
					):Play()

					TweenService:Create(SelectedData.Button.Title,
						TweenInfo.new(.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
						{TextTransparency = 0}
					):Play()

					return DropdownConfig.Callback(SelectedData.Name)
				end

				local OriginalDropdownSet = Dropdown.Set
				function Dropdown:Set(Value)
					if DropdownConfig.MultipleSelection and type(Value) == "table" then
						local current = table.clone(self.Value)
						for _, selectedId in ipairs(current) do
							OriginalDropdownSet(self, selectedId)
						end
						for _, requestedValue in ipairs(Value) do
							OriginalDropdownSet(self, requestedValue)
						end
						return self.Value
					end
					return OriginalDropdownSet(self, Value)
				end

				function Dropdown:Get()
					if DropdownConfig.MultipleSelection then
						local names = {}
						for _, selectedId in ipairs(self.Value) do
							for _, data in ipairs(self.Buttons) do
								if data.Id == selectedId then
									table.insert(names, data.Name)
									break
								end
							end
						end
						return names
					end
					return self.Value
				end

				function Dropdown:Has(Value)
					if DropdownConfig.MultipleSelection then
						return table.find(self:Get(), Value) ~= nil
					end
					return self.Value == Value
				end

				function Dropdown:SetOnce(Value)
					return self:Set(Value)
				end

				function Dropdown:UpdSel()
					if DropdownConfig.MultipleSelection then
						local selectedNames = {}
						for _, data in ipairs(self.Buttons) do
							local selected = table.find(self.Value, data.Id) ~= nil
							TweenService:Create(data.Button, TweenInfo.new(0.15), {
								BackgroundTransparency = selected and 0 or 1
							}):Play()
							if data.Button:FindFirstChild("Title") then
								TweenService:Create(data.Button.Title, TweenInfo.new(0.15), {
									TextTransparency = selected and 0 or 0.4
								}):Play()
							end
							if selected then table.insert(selectedNames, data.Name) end
						end
						DropdownFrame.F.Selected.Text = table.concat(selectedNames, ", ")
					else
						for _, data in ipairs(self.Buttons) do
							local selected = data.Name == self.Value
							TweenService:Create(data.Button, TweenInfo.new(0.15), {
								BackgroundTransparency = selected and 0 or 1
							}):Play()
							if data.Button:FindFirstChild("Title") then
								TweenService:Create(data.Button.Title, TweenInfo.new(0.15), {
									TextTransparency = selected and 0 or 0.4
								}):Play()
							end
						end
						DropdownFrame.F.Selected.Text = tostring(self.Value)
					end
				end

				function Dropdown:UpdVis(Value)
					if Value ~= nil then self.Toggled = Value == true end
					DropdownFrame.F.Line.Visible = self.Toggled
					TweenService:Create(DropdownFrame.F.Ico, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
						Rotation = self.Toggled and 180 or 0
					}):Play()

					local visibleHeight = 0
					local count = 0
					for _, data in pairs(self.Buttons) do
						local button = typeof(data) == "table" and data.Button or data
						if button.Visible then
							visibleHeight += button.AbsoluteSize.Y
							count += 1
							if count >= MaxElements then break end
						end
					end

					TweenService:Create(DropdownFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
						Size = self.Toggled and UDim2.new(1, 0, 0, 38 + visibleHeight) or UDim2.new(1, 0, 0, 38)
					}):Play()
				end

				AddConnection(Click.MouseButton1Click, function()
					Dropdown.Toggled = not Dropdown.Toggled
					Dropdown:UpdVis()
				end)

				Dropdown:Refresh(Dropdown.Options, false)
				Dropdown:Set(initialDefault)
				table.insert(OrionLib.Dropdowns, Dropdown)

				if DropdownConfig.Flag then
					OrionLib.Flags[DropdownConfig.Flag] = Dropdown
				end

				return Dropdown
			end

